{
  // -----------------------------------------------------------
  //              Item Obliterator by ElocinDev
  // -----------------------------------------------------------
  //  
  // How to add items?
  //   - They are json strings, so you need to separate each
  //     entry with a comma, except the last
  //   - If you start an entry with !, it will be treated as a regular expression
  //     Example: "!minecraft:.*_sword" to disable all swords
  //  
  // -----------------------------------------------------------
  // Do not touch this
  "configVersion": 2,
  // -----------------------------------------------------------
  // Items here will be unusable completely
  //    Example: minecraft:diamond
  "blacklisted_items": [
"confluence:dynamite",
"confluence:bouncy_dynamite",
"confluence:sticky_dynamite",
"confluence:bomb",
"confluence:bouncy_bomb",
"confluence:sticky_bomb",
"confluence:chlorophyte_repeater",
"confluence:titanium_trident",
"confluence:daedalus_storm_bow",
"confluence:cobalt_sword",
"confluence:cobalt_repeater",
"confluence:palladium_repeater",
"confluence:mythril_repeater",
"confluence:orichalcum_repeater",
"confluence:adamantite_repeater",
"confluence:titanium_repeater",
"confluence:hallowed_repeater",
"confluence:adamantite_glaive",
"confluence:palladium_sword",
"confluence:mythril_sword",
"confluence:orichalcum_sword",
"confluence:adamantite_sword",
"confluence:flower_of_frost",
"confluence:crystal_vile_shard",
"confluence:cursed_flames",
"confluence:golden_shower",
"confluence:titanium_sword",
"confluence:palladium_pike",
"confluence:orichalcum_halberd",
"confluence:mythril_halberd",
"confluence:titanium_trident",
"confluence:orichalcum_headgear",
"confluence:orichalcum_mask",
"confluence:orichalcum_helmet",
"confluence:orichalcum_chestplate",
"confluence:orichalcum_leggings",
"confluence:orichalcum_boots",
"confluence:cobalt_mask",
"confluence:cobalt_hat",
"confluence:cobalt_helmet",
"confluence:cobalt_chestplate",
"confluence:cobalt_leggings",
"confluence:cobalt_boots",
"confluence:palladium_mask",
"confluence:palladium_headgear",
"confluence:palladium_helmet",
"confluence:palladium_chestplate",
"confluence:palladium_leggings",
"confluence:palladium_boots",
"confluence:mythril_hood",
"confluence:mythril_hat",
"confluence:mythril_helmet",
"confluence:mythril_chestplate",
"confluence:mythril_leggings",
"confluence:mythril_boots",
"confluence:adamantite_headgear",
"confluence:adamantite_mask",
"confluence:adamantite_helmet",
"confluence:adamantite_chestplate",
"confluence:adamantite_leggings",
"confluence:adamantite_boots",
"confluence:titanium_headgear",
"confluence:titanium_mask",
"confluence:titanium_helmet",
"confluence:titanium_chestplate",
"confluence:titanium_leggings",
"confluence:titanium_boots",
"confluence:developer_sword",
"confluence:developer_boomerang",
"confluence:developer_bow",
"confluence:dev_fishing_rod",
"confluence:chlorophyte_partisan",
"confluence:gungnir",
  ],
  // -----------------------------------------------------------
  // Removes an item if it contains certain nbt tag. If the whole entry (or expression) is present, the item gets removed.
  // Use with caution! This is a very expensive operation and can cause lag if you have a lot of items blacklisted.
  // 	
  // 	 Example to disable a regeneration potion: Potion:"minecraft:regeneration"
  // 	
  // 	 You can also use regular expressions by starting the value with !
  "blacklisted_nbt": [],
  // -----------------------------------------------------------
  // Items here will not be able to be right-clicked (Interact)
  //    Example: minecraft:apple
  "only_disable_interactions": [
    "examplemod:example_item"
  ],
  // -----------------------------------------------------------
  // Items here will not be able to be used to attack
  //    Example: minecraft:diamond_sword
  "only_disable_attacks": [
    "examplemod:example_item"
  ],
  // -----------------------------------------------------------
  // Items here will get their recipes disabled
  // Keep in mind this already is applied to blacklisted items
  "only_disable_recipes": [
    "skyfalltesla:nikolas_journal"
  ],
  // -----------------------------------------------------------
  // If true, the mod will use a hashset to handle the blacklisted items
  // This is a more optimized approach only if you have a lot of items blacklisted (20 or more is recommended)
  // If you just have a small amount of items blacklisted, keep this false
  //  
  // [!] Enabling this will disable all regular expressions
  // [!] Does not apply to NBT, only item blacklist / interaction / attack
  "use_hashmap_optimizations": true
}